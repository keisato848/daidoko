{
  "expo": {
    "name": "だいどこ",
    "slug": "daidoko",
    "version": "1.4.0",
    "orientation": "default",
    "scheme": "daidoko",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0805",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0805"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.daidoko.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.daidoko.app",
      "versionCode": 10011,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0805"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.20"
          }
        }
      ],
      "./plugins/withKotlinMetadataSkip",
      "./plugins/withDaidokoBackupRules",
      [
        "expo-image-picker",
        {
          "photosPermission": "レシピ写真を選択するために写真ライブラリへのアクセスを使用します。",
          "cameraPermission": "レシピ写真を撮影するためにカメラを使用します。"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "バーコード（JAN）を読み取るためにカメラを使用します。"
        }
      ],
      "./plugins/withDaidokoOcr",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2633806931583277~2829239666",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true,
          "userTrackingUsageDescription": "広告の表示回数の制御と不正防止のために利用します。"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ae12a2e5-cd4a-4dd4-a5f5-741511a52281"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "keisato848"
  }
}
