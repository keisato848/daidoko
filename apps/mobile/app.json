{
  "expo": {
    "name": "だいどこ",
    "slug": "daidoko",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "daidoko",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0805",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0805"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.daidoko.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.daidoko.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0805"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "レシピ写真を選択するために写真ライブラリへのアクセスを使用します。",
          "cameraPermission": "レシピ写真を撮影するためにカメラを使用します。"
        }
      ],
      "./plugins/withDaidokoOcr"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ae12a2e5-cd4a-4dd4-a5f5-741511a52281"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "keisato848"
  }
}
