    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@daidoko/shared": "workspace:*",
    "@expo/metro-runtime": "~3.2.3",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.40.0",
    "drizzle-orm": "^0.30.0",
    "expo": "~51.0.0",
    "expo-keep-awake": "^55.0.8",
    "expo-router": "~3.5.0",
    "expo-sqlite": "~14.0.0",
    "expo-updates": "~0.25.28",
    "lucide-react-native": "^0.395.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.51.0",
    "react-native": "0.74.0",
    "react-native-web": "~0.19.10",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~18.2.0",
    "drizzle-kit": "^0.20.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
