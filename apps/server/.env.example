# サーバー設定
PORT=3000
NODE_ENV=development

# データベース
DATABASE_URL=postgresql://daidoko:password@localhost:5432/daidoko_dev

# JWT（RS256 鍵ペア — 本番では外部シークレット管理ツールを使うこと）
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# S3 互換ストレージ（MinIO ローカル or Cloudflare R2）
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=daidoko-photos
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# AI API（料理写真レシピ推論 / OCR テキスト構造化）
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash          # 任意（既定: gemini-2.5-flash）
# INFER_DAILY_LIMIT=20                    # 任意（1クライアント(IP)/日の推論上限。0で無効）
# INFER_GLOBAL_DAILY_LIMIT=200           # 任意（全体/日の推論上限＝コスト上限。0で無効）
# ANTHROPIC_API_KEY=your_key_here

# Sentry（エラー監視 — 省略可）
# SENTRY_DSN=https://xxx@sentry.io/xxx
